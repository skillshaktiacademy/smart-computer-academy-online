# SPA fallback for Apache / cPanel shared hosting:
# serve index.html for any path that isn't a real file or directory,
# so client-side routes (e.g. /courses, /admission) work on refresh/deep-link.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
